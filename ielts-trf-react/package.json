{
  "name": "ielts-trf-react",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch server/server.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "vite build && node server/server.js",
    "server": "node server/server.js"
  },
  "dependencies": {
    "express": "^4.21.1",
    "jszip": "^3.10.1",
    "puppeteer": "^23.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "vite": "^5.4.10"
  }
}
